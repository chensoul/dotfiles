# -----------------------------------------------------------------------------
# Ghostty Configuration
# https://ghostty.org/docs/config
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# 窗口设置
# -----------------------------------------------------------------------------
# 窗口大小
width = 120
height = 40

# 窗口透明度 (0.0-1.0)
background-opacity = 0.95

# 窗口装饰 (full, none, transparent)
window-decoration = true

# 启动时最大化
# maximize = true

# -----------------------------------------------------------------------------
# 字体设置
# -----------------------------------------------------------------------------
# 主要字体 (使用 Nerd Font 以支持图标)
font-family = "JetBrainsMono Nerd Font"

# 字体大小
font-size = 14

# 禁用连字 (如果需要)
# font-ligatures = false

# -----------------------------------------------------------------------------
# 主题与颜色
# -----------------------------------------------------------------------------
# 使用系统主题或 dark/light
theme = "dark"

# 光标样式 (block, underline, bar)
cursor-style = block

# 光标闪烁
cursor-style-blink = true

# -----------------------------------------------------------------------------
# 终端行为
# -----------------------------------------------------------------------------
# 确认关闭终端 (当有运行中的进程时)
confirm-close-shell = true

# 复制时自动选择
copy-on-select = true

# 鼠标报告 (用于 tmux 等)
mouse-reporting = true

# -----------------------------------------------------------------------------
# 滚动历史
# -----------------------------------------------------------------------------
scrollback-lines = 10000

# -----------------------------------------------------------------------------
# 铃声
# -----------------------------------------------------------------------------
# 禁用终端铃声
audible-bell = false

# -----------------------------------------------------------------------------
# 快速启动 (Quick Start)
# -----------------------------------------------------------------------------
# 使用 fish shell (如果已安装)
# shell = "/opt/homebrew/bin/fish"

# -----------------------------------------------------------------------------
# 键盘快捷键
# -----------------------------------------------------------------------------
# 新建标签页
# keybind = "ctrl+shift+t:new_tab"

# 关闭标签页
# keybind = "ctrl+shift+w:close_tab"

# 切换全屏
# keybind = "ctrl+shift+f:toggle_fullscreen"

# -----------------------------------------------------------------------------
# macOS 特定设置
# -----------------------------------------------------------------------------
# 使用 Option 键作为 Meta 键
macos-option-as-alt = true

# 禁用 macOS 窗口阴影
# macos-window-shadow = false

# -----------------------------------------------------------------------------
# URL 预览
# -----------------------------------------------------------------------------
# 悬停时显示 URL 预览
# hyperlink-preview = true

# -----------------------------------------------------------------------------
# 其他选项
# -----------------------------------------------------------------------------
# 自动更新 (如果通过 Sparkle 安装)
# auto-update = true

# 检查更新间隔 (天)
# auto-update-interval = 7
