# -----------------------------------------------------------------------------
# Ghostty Configuration
# https://ghostty.org/docs/config
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# 窗口设置
# -----------------------------------------------------------------------------
# 窗口大小（Ghostty 1.3+）
window-width = 120
window-height = 40

# 窗口透明度 (0.0-1.0)
background-opacity = 0.95

# 窗口装饰 (full, none, transparent)
window-decoration = true

# 启动时最大化
# maximize = true

# -----------------------------------------------------------------------------
# 字体设置
# -----------------------------------------------------------------------------
# 主要字体 (使用 Nerd Font 以支持图标)
font-family = "JetBrainsMono Nerd Font"

# 字体大小
font-size = 14

# 禁用连字 (如果需要)
# font-ligatures = false

# -----------------------------------------------------------------------------
# 主题与颜色
# -----------------------------------------------------------------------------

# 光标样式 (block, underline, bar)
cursor-style = block

# 光标闪烁
cursor-style-blink = true

# -----------------------------------------------------------------------------
# 终端行为
# -----------------------------------------------------------------------------
# 确认关闭终端 (当有运行中的进程时)
confirm-close-surface = true

# 复制时自动选择
copy-on-select = true

# 鼠标报告 (用于 tmux 等)
mouse-reporting = true

# -----------------------------------------------------------------------------
# 滚动历史
# -----------------------------------------------------------------------------
scrollback-limit = 100000000

